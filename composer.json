{
  "name": "flarme/multitenancy-toolkit",
  "description": "A simple library around spatie multitenancy package adding some features.",
  "type": "library",
  "require": {
    "spatie/laravel-multitenancy": "^4.0"
  },
  "require-dev": {
    "laravel/pint": "^1.27",
    "phpstan/phpstan": "^2.1",
    "orchestra/testbench": "^10.9",
    "pestphp/pest": "^4.4",
    "pestphp/pest-plugin-laravel": "^4.1"
  },
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "Flarme\\MultitenancyToolkit\\": "src/",
      "Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Flarme\\MultitenancyToolkit\\MultitenancyToolkitProvider"
      ]
    }
  },
  "authors": [
    {
      "name": "Flarme",
      "email": "contact@flarme.com"
    }
  ],
  "minimum-stability": "stable",
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  }
}
